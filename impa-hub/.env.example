# IMPA HUB - Configuração
# Copie este arquivo para .env e configure os valores

# ========== Servidor ==========
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
BASE_URL=http://localhost:8080

# ========== Banco de Dados ==========
DATABASE_URL=postgres://impa:impa123@localhost:5432/impa_hub?sslmode=disable

# ========== JWT ==========
JWT_SECRET=sua-chave-secreta-aqui-mude-isso
JWT_EXPIRATION_HOURS=24

# ========== SuperAdmin Padrão ==========
ADMIN_EMAIL=admin@impa.hub
ADMIN_PASSWORD=admin123

# ========== Logs ==========
LOG_LEVEL=info

# ========== CORS ==========
CORS_ORIGINS=*
